# Base URL the frontend uses to reach the backend API.
# - Two-server local development (recommended while building): the
#   Vite dev server runs on :5173, backend on :4000 — keep this pointing
#   at the backend's own port.
# - Single-process production mode (Phase 13): once the backend serves
#   the built frontend itself, the page and the API share an origin, so
#   this can stay the same value — no CORS issue either way since it's
#   the same host:port at that point.
VITE_API_BASE_URL=http://localhost:4000